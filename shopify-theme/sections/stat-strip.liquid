<section class="stat-strip">
  <div class="stat-strip__grid page-width">
    <div class="stat-strip__item">
      <span class="stat-strip__value">3–5g</span>
      <span class="stat-strip__label">clinical dose per serving</span>
    </div>
    <div class="stat-strip__item">
      <span class="stat-strip__value">200mg</span>
      <span class="stat-strip__label">magnesium glycinate</span>
    </div>
    <div class="stat-strip__item">
      <span class="stat-strip__value">0</span>
      <span class="stat-strip__label">fillers or sweeteners</span>
    </div>
    <div class="stat-strip__item">
      <span class="stat-strip__value">USA</span>
      <span class="stat-strip__label">manufactured &amp; tested</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stat strip",
  "settings": []
}
{% endschema %}
