<section class="how-it-works" id="how-it-works">
  <div class="how-it-works__inner page-width">
    <p class="how-it-works__eyebrow">The batch model</p>
    <h2 class="how-it-works__headline display-md">Four steps. No surprises.</h2>

    <div class="how-it-works__steps">
      <div class="hiw-step">
        <div class="hiw-step__num">1</div>
        <div class="hiw-step__content">
          <h3 class="hiw-step__title">Reserve your place</h3>
          <p class="hiw-step__body">We open a short reservation window. Secure your spot in Batch 01. No charge yet — your card is authorized but not captured.</p>
        </div>
      </div>

      <div class="hiw-step">
        <div class="hiw-step__num">2</div>
        <div class="hiw-step__content">
          <h3 class="hiw-step__title">We mix your batch</h3>
          <p class="hiw-step__body">Once the window closes, we mix exactly what was ordered. No leftover inventory. No warehouse shelves.</p>
        </div>
      </div>

      <div class="hiw-step">
        <div class="hiw-step__num">3</div>
        <div class="hiw-step__content">
          <h3 class="hiw-step__title">Charged on ship</h3>
          <p class="hiw-step__body">Your card is only charged when your order ships — never before. We notify you 48 hours before capture.</p>
        </div>
      </div>

      <div class="hiw-step">
        <div class="hiw-step__num">4</div>
        <div class="hiw-step__content">
          <h3 class="hiw-step__title">Next batch opens</h3>
          <p class="hiw-step__body">When your supply runs low, you'll get early access to the next batch. No auto-renew. No pressure.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": []
}
{% endschema %}
