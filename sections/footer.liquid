<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">
      <div>
        <div class="site-footer__brand">{{ settings.brand_name | default: shop.name }}</div>
        <p class="site-footer__tagline">{{ settings.brand_tagline }}</p>
      </div>
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div {{ block.shopify_attributes }}>
            <div class="site-footer__heading">{{ block.settings.heading }}</div>
            <ul class="site-footer__list">
              {%- if block.settings.menu != blank -%}
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <div>© {{ 'now' | date: "%Y" }} {{ settings.brand_name | default: shop.name }}. All rights reserved.</div>
      <div>Made in small batches. Tested in every one.</div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Shop" } },
        { "type": "menu", "settings": { "heading": "Company" } },
        { "type": "menu", "settings": { "heading": "Help" } }
      ]
    }
  ]
}
{% endschema %}
